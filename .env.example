# Optional OCR adapter
OCR_PROVIDER=custom
OCR_API_URL=
OCR_API_KEY=

# Optional embedding adapter
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding

# Admin
ADMIN_EMAILS=1305813360@qq.com

# Python executable on Linux server
PYTHON_BIN=python3
