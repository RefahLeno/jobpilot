PORT=4173
NODE_ENV=production
COOKIE_SECURE=true

# DeepSeek
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat

# JD crawling
TAVILY_API_KEY=your_tavily_api_key

# Optional OCR adapter
OCR_LANGS=chi_sim+eng
OCR_PROVIDER=custom
OCR_API_URL=
OCR_API_KEY=

# Optional embedding adapter
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding

# Admin
ADMIN_EMAILS=1305813360@qq.com

# Python executable in the Railway Docker image
PYTHON_BIN=/opt/venv/bin/python
